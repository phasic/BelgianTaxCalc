# Copy to frontend/.env.local and fill values from Firebase Console → Project settings → Your apps (Web).
# Never commit .env.local.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firebase Cloud Function URL for the OpenFIGI proxy (Firebase console → Functions → openFigiProxy URL).
# Only used in production builds; the Vite dev server proxies /openfigi directly.
VITE_OPENFIGI_PROXY_URL=
